# Maui Alert Hub Backend Configuration
# Copy this to .env and fill in your values

# NWS API requires a User-Agent string (no API key needed)
NWS_USER_AGENT=MauiAlertHub/1.0 (your-email@example.com)

# Database (SQLite for dev, PostgreSQL URL for prod)
DATABASE_URL=sqlite:///./maui_alert_hub.db

# How often to scrape county data (in minutes)
SCRAPE_INTERVAL_MINUTES=5

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# Frontend URL for CORS
CORS_ORIGINS=http://localhost:5173

# Environment (development, production)
ENVIRONMENT=development
